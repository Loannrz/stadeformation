# Copiez ce fichier en .env.local pour le développement local.
# En production, définissez ces variables dans les paramètres de votre hébergeur (Vercel, etc.).

# Mot de passe pour accéder à /admin
ADMIN_PASSWORD=changez-moi

# Jeton de session (valeur du cookie admin-token) — utilisez une chaîne longue et aléatoire
ADMIN_SESSION_TOKEN=changez-moi-aussi-avec-une-valeur-secrete
